# data & artifacts (never commit raw competition data / audio)
data/raw/*
data/processed/*
!**/.gitkeep
models/*
!models/.gitkeep
outputs/*
!outputs/.gitkeep
experiments/artifacts/*
!experiments/artifacts/.gitkeep
reports/figures/*
!reports/figures/.gitkeep

# audio / archives (large)
*.wav
*.zip
*.npy

# python / uv
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/
.pytest_cache/
*.egg-info/
uv.lock

# torch / timm caches
.cache/
wandb/

# credentials
*.kaggle
kaggle.json
access_token
.env

# editor / os
.DS_Store
.vscode/
.idea/
